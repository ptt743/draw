        <mxCell id="-DmCGCNFtCowsvC-I4bx-22" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Comic Sans MS;strokeWidth=0.5;fontSize=10;" value="&lt;div&gt;long long Pow(long long a, long long b) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;if (!b) return 1ll;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; long long x = pow(a, b / 2);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; long long half_pow = (x * x) % mod;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if (b % 2 == 0)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;return half_pow;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;else&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;return (half_pow * (a % mod)) % mod;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;" vertex="1">
