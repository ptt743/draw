        <mxCell id="-DmCGCNFtCowsvC-I4bx-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Comic Sans MS;strokeWidth=0.5;fontSize=10;" value="&lt;div&gt;long long Mul(long long a, long long b) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if (!b) return 0;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; long long x = Mul(a, b / 2);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if (b % 2 == 0)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return 2 * x % m;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; else&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return (2 * x + a) % m;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;" vertex="1">
