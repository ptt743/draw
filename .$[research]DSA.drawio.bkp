        <mxCell id="IvPajCChKvYk8BWptkef-23" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=10;fontFamily=Comic Sans MS;" value="&lt;font style=&quot;background-color: rgb(255, 230, 204);&quot;&gt;BFS | BFS 0 1&lt;/font&gt;" vertex="1">
