        <mxCell id="HDKpm5i9qXrigkiqiV-I-9" value="Configs&lt;div&gt;* persist : true/false&lt;/div&gt;&lt;div&gt;* multiWatcher : true/false&lt;/div&gt;&lt;div&gt;*&amp;nbsp;neventsPerPackage: number of event which could be send in a packet&lt;/div&gt;&lt;div&gt;*&amp;nbsp;eventsRecv: list of events instance is following&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" vertex="1" parent="1">
