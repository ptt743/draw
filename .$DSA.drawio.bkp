        <mxCell id="-DmCGCNFtCowsvC-I4bx-8" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;fontFamily=Comic Sans MS;" value="&lt;div&gt;int&amp;nbsp;&lt;b&gt;gcd&lt;/b&gt;(int a, int b)&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if (b == 0) return a;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; return gcd(b, a % b);&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;" vertex="1">
