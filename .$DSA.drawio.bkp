        <mxCell id="2UC4lkJaAp2TDeO5gQIq-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;strokeColor=none;" value="&lt;span style=&quot;background-color: rgb(255, 204, 204);&quot;&gt;basic number theory&lt;/span&gt;" vertex="1">
