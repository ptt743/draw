        <mxCell id="efJcOQTv-WqSf4oPIb1X-73" value="&lt;div&gt;(MK, CKnext) = KDF-CK(CKcurrent)&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; // HMAC-SHA-256&lt;br&gt;&lt;div&gt;MK tách thành {AES-GCM key, nonce, MAC key} rồi dùng một lần (Single-use encryption key).&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CKnext trở thành CKcurrent của lần gửi kế tiếp.&lt;/div&gt;&lt;div&gt;→ Điều này cho Forward Secrecy (FS): lộ một MK không giúp giải được những MK đã xoá.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="414" y="1480" width="606" height="90" as="geometry" />
        </mxCell>
        <mxCell id="efJcOQTv-WqSf4oPIb1X-80" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="efJcOQTv-WqSf4oPIb1X-77" target="efJcOQTv-WqSf4oPIb1X-79">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="efJcOQTv-WqSf4oPIb1X-81" value="nhận gói tin chứa public-key DH mới (DHy)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" connectable="0" vertex="1" parent="efJcOQTv-WqSf4oPIb1X-80">
          <mxGeometry x="-0.1869" y="-3" relative="1" as="geometry">
