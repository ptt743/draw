        <mxCell id="efJcOQTv-WqSf4oPIb1X-79" value="&lt;div&gt;RootKey&#39; = HKDF(RootKey || DH(our_sk, DHy))&lt;/div&gt;&lt;div&gt;ChainKey_recv&amp;nbsp; = HKDF-Expand(RootKey&#39;, &quot;chain-recv&quot;)&lt;/div&gt;&lt;div&gt;ChainKey_send&amp;nbsp; = HKDF-Expand(RootKey&#39;, &quot;chain-send&quot;)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="600" y="1670" width="340" height="65" as="geometry" />
        </mxCell>
        <mxCell id="efJcOQTv-WqSf4oPIb1X-83" value="Toàn bộ CK cũ bị xoá; chuỗi khoá sang “đời” mới." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1020" y="1682.5" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="efJcOQTv-WqSf4oPIb1X-85" value="&lt;div&gt;{DHy, PN, N_sending_chain}&lt;br&gt;&lt;div&gt;DHy chỉ xuất hiện khi bắt đầu một DH-ratchet.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;PN (Previous Chain Length) cho phép bên nhận biết phải bỏ qua bao nhiêu MK rỗng.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;N là chỉ số tin nhắn trong chuỗi hiện tại.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="250" y="1570" width="530" height="100" as="geometry" />
        </mxCell>
        <mxCell id="twnL3EoZUUSzebQJkol8-1" value="Đặt lại bộ đếm N_s ← 0, N_r ← 0." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="600" y="1739" width="310" height="41" as="geometry" />
        </mxCell>
        <mxCell id="twnL3EoZUUSzebQJkol8-2" value="- có handle sai order&amp;nbsp;&lt;div&gt;&lt;div&gt;d = Ns - N_r&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; # số nấc phải nhảy&lt;/div&gt;&lt;div&gt;if d &amp;lt; 0:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # tin cũ (hoặc phát lại)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if MK in skipped: dùng &amp;amp; xoá MK&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; else: bỏ gói&amp;nbsp; ➜ replay/duplicate&lt;/div&gt;&lt;div&gt;elif 0 &amp;lt; d &amp;lt;= MAX_SKIP:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; for k in range(N_r, Ns):&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; # sinh &amp;amp; lưu khoá bị nhảy&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; MKk, CK_recv = KDF_CK(CK_recv)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; skipped[k]&amp;nbsp; &amp;nbsp;= MKk&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; # lưu tạm&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # bây giờ CK_recv tương ứng với Ns&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; MKs, CK_recv = KDF_CK(CK_recv)&amp;nbsp; &amp;nbsp; # khoá của gói đang xét&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; decrypt(payload, MKs)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; N_r = Ns + 1&lt;/div&gt;&lt;div&gt;else:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; # d quá lớn ➜ nghi DoS, bỏ gói&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="970" y="1284.5" width="440" height="247" as="geometry" />
        </mxCell>
        <mxCell id="3FWqsLx4zBzv8aboLwaa-9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontFamily=Comic Sans MS;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="3FWqsLx4zBzv8aboLwaa-2" target="3FWqsLx4zBzv8aboLwaa-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="3FWqsLx4zBzv8aboLwaa-10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontFamily=Comic Sans MS;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="3FWqsLx4zBzv8aboLwaa-2" target="3FWqsLx4zBzv8aboLwaa-8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="3FWqsLx4zBzv8aboLwaa-12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;fontFamily=Comic Sans MS;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="3FWqsLx4zBzv8aboLwaa-2" target="3FWqsLx4zBzv8aboLwaa-5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="3FWqsLx4zBzv8aboLwaa-13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fontFamily=Comic Sans MS;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="3FWqsLx4zBzv8aboLwaa-2" target="3FWqsLx4zBzv8aboLwaa-6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="3FWqsLx4zBzv8aboLwaa-2" value="E2E Properties" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1993" y="1404" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="3FWqsLx4zBzv8aboLwaa-3" value="&lt;b&gt;Confidentiality&lt;/b&gt; :&amp;nbsp;&lt;table&gt;&lt;tbody&gt;&lt;tr data-end=&quot;683&quot; data-start=&quot;551&quot;&gt;&lt;td data-end=&quot;683&quot; data-start=&quot;590&quot; data-col-size=&quot;md&quot;&gt;&lt;/td&gt;&lt;td data-end=&quot;683&quot; data-start=&quot;590&quot; data-col-size=&quot;md&quot;&gt;Only the sender and the recipient can read the content. Intermediate servers cannot decrypt it.&lt;/td&gt;&lt;td data-end=&quot;683&quot; data-start=&quot;590&quot; data-col-size=&quot;md&quot;&gt;&lt;br&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;table style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;tbody&gt;&lt;tr data-end=&quot;815&quot; data-start=&quot;684&quot;&gt;&lt;td data-col-size=&quot;sm&quot; data-end=&quot;722&quot; data-start=&quot;684&quot;&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="1947" y="1229.5" width="262" height="55" as="geometry" />
        </mxCell>
        <mxCell id="3FWqsLx4zBzv8aboLwaa-4" value="&lt;b&gt;Authentication&lt;/b&gt; :&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;i&gt;Verify identity and prevent spoofing.&lt;/i&gt;&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="2213" y="1324" width="260" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3FWqsLx4zBzv8aboLwaa-5" value="&lt;b&gt;Message&lt;/b&gt; &lt;b&gt;Integrity&lt;/b&gt; :&amp;nbsp;&lt;table&gt;&lt;tbody&gt;&lt;tr data-start=&quot;1081&quot; data-end=&quot;1213&quot;&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;1120&quot; data-end=&quot;1213&quot; style=&quot;&quot;&gt;&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;1120&quot; data-end=&quot;1213&quot;&gt;Message integrity is ensured during transmission; any attempt at tampering is identified and denied.&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;1120&quot; data-end=&quot;1213&quot;&gt;&lt;br&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;table style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;tbody&gt;&lt;tr data-start=&quot;1214&quot; data-end=&quot;1344&quot;&gt;&lt;td data-start=&quot;1214&quot; data-end=&quot;1252&quot; data-col-size=&quot;sm&quot;&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="1662" y="1485.5" width="281" height="66.5" as="geometry" />
        </mxCell>
        <mxCell id="3FWqsLx4zBzv8aboLwaa-6" value="&lt;b&gt;Forward&lt;/b&gt;&amp;nbsp;&lt;b&gt;Secrecy&lt;/b&gt; :&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;Even if the current key is compromised, previous messages remain secure thanks to key rotation after each session or message.&lt;/span&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="1663" y="1324" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3FWqsLx4zBzv8aboLwaa-8" value="&lt;b&gt;Post-Compromise Security&lt;/b&gt; :&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;If temporarily compromised, the system can autonomously restore its security in subsequent sessions.&lt;/span&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="2213" y="1488" width="233" height="61.5" as="geometry" />
        </mxCell>
        <mxCell id="3FWqsLx4zBzv8aboLwaa-11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.497;entryY=0.928;entryDx=0;entryDy=0;entryPerimeter=0;fontFamily=Comic Sans MS;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="3FWqsLx4zBzv8aboLwaa-2" target="3FWqsLx4zBzv8aboLwaa-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="0qQn_NzQNuPvSGY9M77I-1" value="&lt;div&gt;DHs = (priv, pub) → khóa DH riêng (của mình)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;DHr → khóa công khai mới nhất nhận được từ đối phương&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;RK → RootKey&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CKs → chain key để gửi&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CKr → chain key để nhận&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Ns → số tin đã gửi trong chuỗi hiện tại&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Nr → số tin đã nhận trong chuỗi hiện tại&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;PN → số tin bên kia đã gửi trước khi đổi DHy&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="240" y="1820" width="500" height="240" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
