        <mxCell id="efJcOQTv-WqSf4oPIb1X-77" value="userA" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontColor=#990000;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="210" y="1680" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="efJcOQTv-WqSf4oPIb1X-84" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="efJcOQTv-WqSf4oPIb1X-79" target="efJcOQTv-WqSf4oPIb1X-83">
