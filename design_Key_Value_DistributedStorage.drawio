        <mxCell id="aUNtAYhIRR93k3x2W3pg-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font face=&quot;Comic Sans MS&quot; style=&quot;background-color: rgb(229, 204, 255);&quot;&gt;layer follow-up&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="120" x="-10" y="190" as="geometry" />
