        <mxCell id="bwjHSVQv5VCAhcKKyRjm-10" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="&lt;font face=&quot;Comic Sans MS&quot; style=&quot;background-color: rgb(255, 255, 204);&quot;&gt;need to cover&lt;/font&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ partition + replication&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+&amp;nbsp; quorum r + r &amp;gt; n and it&#39;s practical significance, sloppy quorum &amp;amp; hinted handoff for away&amp;nbsp; writable system , trade-off when&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ versioning &amp;amp; conflict vector clock, structure,&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ anti-entropy : read-repair &amp;amp; background repair by merkle tree&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ membership &amp;amp; failure detection gossip protocol , seed node&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ storage engine&amp;nbsp; &amp;nbsp;in each node : LSM-tree , B-tree for workload write-heavy, WAL, memtable/sstable, bloom filter&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ request routing : coordinator&amp;nbsp; node vs partition-aware client&amp;nbsp;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="370" x="-50" y="560" as="geometry" />
        </mxCell>
