        <mxCell id="bwjHSVQv5VCAhcKKyRjm-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="&lt;font face=&quot;Comic Sans MS&quot; style=&quot;background-color: rgb(255, 204, 204);&quot;&gt;non-functional requirements&lt;/font&gt;&lt;div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ &lt;span style=&quot;background-color: rgb(204, 255, 255);&quot;&gt;data scale&lt;/span&gt; 1 billion keys, ( replicate X3 data), volume data doubling every year&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+&amp;nbsp;&lt;span style=&quot;background-color: rgb(255, 204, 230);&quot;&gt;throughput&lt;/span&gt; : 200k read QPS, 50k write at peak, ratio read:write&amp;nbsp; = 4:1&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ latency SLO :&amp;nbsp; p99 read latency &amp;lt; 10ms and write &amp;lt; 20ms ( intra-regions)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ &lt;span style=&quot;background-color: rgb(255, 255, 204);&quot;&gt;availability&lt;/span&gt;: 99.99% write availability for write path&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ &lt;span style=&quot;background-color: rgb(229, 204, 255);&quot;&gt;durability&lt;/span&gt;: replication factor N = 3 , distributed across at least 2 AZs&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ &lt;span style=&quot;background-color: rgb(204, 255, 204);&quot;&gt;elasticity&lt;/span&gt; : nodes can be add/remove without downtime&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ architecture : fully decentralized&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;+ key distribution: the system must handle hot key&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="460" x="280" y="400" as="geometry" />
        </mxCell>
