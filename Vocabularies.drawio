        <mxCell id="zqkSzmjsO5AOMt-KT8qr-32" value="&lt;div&gt;&amp;nbsp;&lt;b&gt;psychological well-being&lt;/b&gt;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;/ˌsaɪkəˈlɒdʒɪkl ˌwelˈbiːɪŋ/&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;i&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Engaging in regular physical activity has been shown to improve psychological well-being and reduce symptoms of depression and anxiety.&lt;/font&gt;&lt;/i&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" vertex="1" parent="1">
