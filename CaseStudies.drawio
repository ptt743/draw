        <mxCell id="9oHCeac5Po8n7yNW9qxL-18" value="requirements&lt;div&gt;- mobile + web&amp;nbsp;&lt;/div&gt;&lt;div&gt;- make post + see friend&#39;s news feed&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ post :&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*average, user post 2 post a day.&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*&amp;nbsp;10% of posts contain media&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* data store for 5 years&lt;/div&gt;&lt;div&gt;- post sorted in reverse&amp;nbsp;chronological order&lt;/div&gt;&lt;div&gt;- max friend a user have : 500&lt;/div&gt;&lt;div&gt;- volume : 10 mil daily active users (DAU)&lt;/div&gt;&lt;div&gt;- contains media files : image + video&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="-80" y="-40" width="240" height="200" as="geometry" />
        </mxCell>
