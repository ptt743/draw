              <mxPoint x="220" y="430" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="mHYQZA37TOyyGs0ljSMp-6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontFamily=Comic Sans MS;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="877nvy51EfGL9aE2SuXD-1" target="mHYQZA37TOyyGs0ljSMp-5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="220" y="510" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="877nvy51EfGL9aE2SuXD-1" value="&lt;b&gt;&lt;u&gt;Server&lt;/u&gt;&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CPU : 8 cores&lt;/div&gt;&lt;div&gt;&lt;p dir=&quot;auto&quot; style=&quot;white-space-collapse: preserve;&quot;&gt;32GB RAM &lt;/p&gt;&lt;p dir=&quot;auto&quot; style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;SSD NVMe&lt;/span&gt;&lt;/p&gt;&lt;p dir=&quot;auto&quot; style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; Network brandwidth 1Gbps&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=middle;fillColor=#fff2cc;strokeColor=#d6b656;align=center;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="160" y="200" width="170" height="150" as="geometry" />
        </mxCell>
        <mxCell id="mHYQZA37TOyyGs0ljSMp-1" value="&lt;b&gt;Estimate brandwidth&lt;/b&gt; : 1Gbps (125 MB/s)&amp;nbsp;&lt;div&gt;for example each request return 1Mb data&amp;nbsp;&lt;/div&gt;&lt;div&gt;-&amp;gt; serve maximum 125 requests/s&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;strokeColor=#d79b00;dashed=1;fontFamily=Comic Sans MS;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="320" y="400" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="mHYQZA37TOyyGs0ljSMp-3" value="" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontFamily=Comic Sans MS;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="877nvy51EfGL9aE2SuXD-1" target="mHYQZA37TOyyGs0ljSMp-4">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="370" y="330" as="sourcePoint" />
            <mxPoint x="440" y="240" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="mHYQZA37TOyyGs0ljSMp-4" value="&lt;div&gt;&lt;b&gt;1000-5000&lt;/b&gt; simple request (return small json)&lt;/div&gt;&lt;div&gt;&lt;b&gt;10000-50000&lt;/b&gt; with request query static content&amp;nbsp;&lt;/div&gt;&lt;b&gt;100-500&lt;/b&gt; request / second for heavy db query request&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;optimize : request/second = 1 / average execute time x nums of thread.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="400" y="191" width="410" height="92" as="geometry" />
        </mxCell>
        <mxCell id="mHYQZA37TOyyGs0ljSMp-7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontFamily=Comic Sans MS;" edge="1" parent="1" source="mHYQZA37TOyyGs0ljSMp-5" target="mHYQZA37TOyyGs0ljSMp-8">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="680" y="510" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="mHYQZA37TOyyGs0ljSMp-5" value="&lt;u&gt;Estimate time execute for each user&lt;/u&gt;&amp;nbsp;&lt;div&gt;example : each user call 1 request per minute -&amp;gt; 1 million users call&amp;nbsp; 1000000/60 ~ 16.667 request/ second&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;strokeColor=#d79b00;dashed=1;fontFamily=Comic Sans MS;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="320" y="480" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="mHYQZA37TOyyGs0ljSMp-8" value="Each server handle 500 request/ second&lt;div&gt;-&amp;gt; 59 servers&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;align=left;fontFamily=Comic Sans MS;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="690" y="480" width="160" height="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="blrDS_biG2FpDmiSJExg" name="Rate limiter">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="yCVq_pdQRVNkzeqtW5FR-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Comic Sans MS;" value="&lt;div&gt;- Accurately limit excessive requests.&lt;/div&gt;&lt;div&gt;- Low latency. &lt;u&gt;The rate limiter should not slow down HTTP response time.&lt;/u&gt;&lt;/div&gt;&lt;div&gt;- &lt;u&gt;Use as little memory &lt;/u&gt;as possible.&lt;/div&gt;&lt;div&gt;- &lt;u&gt;Distributed rate limiting&lt;/u&gt;. The rate limiter can be shared across multiple servers or&lt;/div&gt;&lt;div&gt;processes.&lt;/div&gt;&lt;div&gt;- Exception handling. &lt;u&gt;Show clear exceptions to users when their requests are throttled.&lt;/u&gt;&lt;/div&gt;&lt;div&gt;- &lt;u&gt;High fault tolerance&lt;/u&gt;. If there are any problems with the rate limiter (for example, a cache&lt;/div&gt;&lt;div&gt;server goes offline), it does not affect the entire system.&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="510" x="-80" y="120" as="geometry" />
