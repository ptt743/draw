        </mxCell>
        <mxCell id="Wqb6fFgbpKCGsUyV0K7X-17" value="&lt;u&gt;&lt;b&gt;Rate-Limiting&lt;br&gt;&lt;/b&gt;&lt;/u&gt;Do in :&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+&amp;nbsp;infrastructure layer&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+&amp;nbsp;application&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;recommend API returns the Retry-After header and clients can use this to determine how long to &quot;back-off&quot; for.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=LDFComicSans;" vertex="1" parent="1">
          <mxGeometry x="440" y="130" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="Wqb6fFgbpKCGsUyV0K7X-20" value="&lt;u&gt;&lt;b&gt;Caching&lt;/b&gt;&lt;/u&gt;&lt;br&gt;+&amp;nbsp;implement cachingto prevent to do expensive DB lookups or calculations." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=LDFComicSans;" vertex="1" parent="1">
          <mxGeometry x="440" y="280" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="Wqb6fFgbpKCGsUyV0K7X-22" value="&lt;u&gt;&lt;b&gt;Circuit-Breaking&lt;br&gt;&lt;/b&gt;&lt;/u&gt;+&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;You could consider adding a circuit breaker to your API so that once you start to see a surge in requests, you open the circuit and prevent more requests being handled. For Go specifically, there are some open-source libraries you can use here such as sony/gobreaker or the one provided by go-kit.&lt;/span&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=LDFComicSans;" vertex="1" parent="1">
          <mxGeometry x="440" y="475" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="Wqb6fFgbpKCGsUyV0K7X-25" value="&lt;u style=&quot;&quot;&gt;&lt;b&gt;Client Changes&lt;br&gt;&lt;/b&gt;&lt;/u&gt;+&amp;nbsp;&amp;nbsp;asking client to implement exponential backoff with a little bit of jitter, to ensure that retried requests are &quot;spread out&quot; in the event of a downtime." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=LDFComicSans;" vertex="1" parent="1">
          <mxGeometry x="440" y="620" width="280" height="100" as="geometry" />
        </mxCell>
