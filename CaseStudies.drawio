        <UserObject label="&lt;div&gt;&lt;b&gt;optimistic lock&lt;/b&gt;&lt;/div&gt;&lt;b&gt;for attempt in 0..N:&lt;br&gt;&lt;/b&gt;&amp;nbsp; row = SELECT status, price, minInc, version FROM auction_current WHERE auction_id=aid&lt;br&gt;&amp;nbsp; if row.status != OPEN or amount &amp;lt; row.price + row.minInc: return REJECT&lt;br&gt;&lt;b&gt;&amp;nbsp; BEGIN TX&lt;br&gt;&lt;/b&gt;&amp;nbsp; rows = UPDATE auction_current&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;SET price=amount, leader=userId, last_bid_id=bidId, version=version+1, updated_at=NOW()&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;WHERE auction_id=aid AND version=row.version&lt;br&gt;&amp;nbsp; if rows == 1:&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; UPSERT bid_history(..., version=row.version+1, status=&#39;ACCEPTED&#39;)&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; COMMIT; return ACCEPTED&lt;br&gt;&lt;b&gt;&amp;nbsp; COMMIT&lt;br&gt;&lt;/b&gt;&amp;nbsp; cur = SELECT price FROM auction_current WHERE auction_id=aid&lt;br&gt;&amp;nbsp; if amount &amp;lt;= cur.price: UPSERT bid_history(..., status=&#39;OUTBID_OR_LOW&#39;); return OUTBID_OR_LOW&lt;br&gt;&lt;b&gt;return RETRY_EXHAUSTED&lt;/b&gt;" id="_jgsV4lO0d0Ov01wdois-4">
          <mxCell style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;dashed=1;" vertex="1" parent="1">
            <mxGeometry x="1697.5" y="-450" width="565" height="230" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
