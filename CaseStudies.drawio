        <mxCell id="ACgiR_8k5SSz8EpK5dFP-2" value="&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Handle race condition&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=4;fontFamily=LDFComicSans;fillColor=#FFFF33;" vertex="1" parent="1">
          <mxGeometry x="1770" y="-320" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ACgiR_8k5SSz8EpK5dFP-3" value="&lt;u&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;&lt;b&gt;Pessimistic locking&lt;/b&gt;&lt;/font&gt;&lt;/u&gt;&lt;div&gt;* before update wallet system lock the record of balance&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ SQL : &lt;b&gt;SELECT ... &lt;u&gt;FOR UPDATE&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ NoSQL : &lt;b&gt;lease-based lock&lt;/b&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Pro&lt;/b&gt; :&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;completely prevent conflict&lt;/div&gt;&lt;div&gt;&lt;b&gt;Cons&lt;/b&gt;: throughput of service decrease because of requests queued for lock.&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=LDFComicSans;" vertex="1" parent="1">
          <mxGeometry x="1960" y="-520" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ACgiR_8k5SSz8EpK5dFP-5" value="&lt;u&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;&lt;b&gt;Optimistic locking&lt;/b&gt;&lt;/font&gt;&lt;/u&gt;&lt;div&gt;* each record of balance have a field of timestamp =&amp;gt;&amp;nbsp;&lt;b&gt;&lt;u&gt;compare and swap&lt;/u&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Pro:&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ high performance under low contention&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ avoid hard-locking resource&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Cons:&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ more complex bcf having to handle retry logic&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=LDFComicSans;" vertex="1" parent="1">
          <mxGeometry x="1960" y="-400" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ACgiR_8k5SSz8EpK5dFP-7" value="&lt;b&gt;&lt;u&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;Distributed locking&lt;/font&gt;&lt;/u&gt;&lt;/b&gt;&lt;div&gt;in micro service env, which have multi nodes =&amp;gt; adding distributed lock =&amp;gt; ensure that only one transaction can happen in a record in any instance&lt;/div&gt;&lt;div&gt;&lt;b&gt;Pro:&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ simple to implement in distributed env&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ completely prevent race condition like pessimistic locking&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Cons:&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ add latency when acquire lock from service&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ when key service down-time -&amp;gt; service payment down&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=LDFComicSans;" vertex="1" parent="1">
          <mxGeometry x="1960" y="-260" width="360" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ACgiR_8k5SSz8EpK5dFP-9" value="&lt;u&gt;&lt;b&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;queue-per-key&lt;/font&gt;&lt;/b&gt;&lt;/u&gt;&lt;div&gt;-&amp;nbsp;replaces explicit locking by naturally serializing transactions per key (wallet ID)&lt;/div&gt;&lt;div&gt;-&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Ensure that no two transactions are ever concurrent on the same wallet&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=LDFComicSans;" vertex="1" parent="1">
          <mxGeometry x="1960" y="-80" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ACgiR_8k5SSz8EpK5dFP-14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontFamily=LDFComicSans;" edge="1" parent="1" source="ACgiR_8k5SSz8EpK5dFP-11" target="ACgiR_8k5SSz8EpK5dFP-13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
