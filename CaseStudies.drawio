        </mxCell>
        <mxCell id="RjiAtdgYc3UGIVJFkeS_-20" value="- SQL databases are well-suited for ensuring ACID properties&lt;div&gt;-&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;We can start by using transactions combined with locks&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Noted :&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;-&amp;gt;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: rgb(255, 255, 51);&quot;&gt;However, when many users bid simultaneously, this design is quite poor&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="2820" y="720" width="320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="RjiAtdgYc3UGIVJFkeS_-22" value="" style="endArrow=classic;html=1;rounded=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;fontFamily=Comic Sans MS;" edge="1" parent="1" source="RjiAtdgYc3UGIVJFkeS_-9" target="RjiAtdgYc3UGIVJFkeS_-18">
