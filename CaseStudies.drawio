        <mxCell id="Wqb6fFgbpKCGsUyV0K7X-13" value="&lt;span style=&quot;background-color: rgb(255, 255, 102);&quot;&gt;Immediate solution&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=LDFComicSans;" vertex="1" parent="1">
