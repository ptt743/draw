        <mxCell id="_jgsV4lO0d0Ov01wdois-2" value="Check price in cache" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontFamily=Comic Sans MS;" connectable="0" vertex="1" parent="_jgsV4lO0d0Ov01wdois-1">
