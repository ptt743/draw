        <mxCell id="b4CpbikTE2RqZqySH7NQ-2" value="Estimated&lt;div&gt;- DAU : 10 mil&lt;/div&gt;&lt;div&gt;=&amp;gt; post QPS : 10ml * 2(posts) / 24 / 3600 ~ 232&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;Peek Post QPS : 232 * 2&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;in each post we have :&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;postId : 64 byte&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;ClientPostId : 8 byte&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;TS : 8Byte&amp;nbsp;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;text : 1MB&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;media : 5MB&lt;br&gt;&lt;/div&gt;&lt;div&gt;estimate Storage media: 5* 2 * 10ml * 20&amp;nbsp;&lt;/div&gt;&lt;div&gt;estimate Storage metadata :&amp;nbsp; (~1,5MB) * 2 * 10ml * 30&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
