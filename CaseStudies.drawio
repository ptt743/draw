        <mxCell id="cpBCgaC1MfF4ZtMjgNiu-35" value="&lt;div&gt;int k&amp;nbsp; &amp;nbsp; &amp;nbsp; = &lt;b&gt;getBucketCount&lt;/b&gt;(userId); // metadata table, current count&lt;/div&gt;&lt;div&gt;int bucket =&lt;b&gt;murmur64&lt;/b&gt;(FollowerId) %B;&lt;/div&gt;&lt;div&gt;long key2 = murmur64(concat64(&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;userId,&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;bucket))&lt;/span&gt;&lt;/div&gt;&lt;div&gt;shard = &lt;b&gt;consistent_hash&lt;/b&gt;(&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;key2&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;)&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;insertEdge&lt;/b&gt;(userId, bucket, FollowerId, …);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Comic Sans MS;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
