        <mxCell id="ewHc8kYxuxDWHBCdIvr7-78" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;fontSize=10;" value="Preemptive &amp;amp; Non-preemptive" vertex="1">
          <mxGeometry height="20" width="190" x="1550" y="1510" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-79" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Comic Sans MS;fontSize=10;" value="&lt;b&gt;Non-preemptive&lt;/b&gt;&lt;div&gt;process run until it terminated or waiting -&amp;gt;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;context switch&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;pro:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Low overhead (fewer context switches)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;cons:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;lead to long waiting times for short process&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="330" x="1180" y="1470" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-80" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Comic Sans MS;fontSize=10;" value="&lt;b&gt;Preemptive&lt;/b&gt;&lt;div&gt;current process can be interrupted and move to waiting queue if a higher-priority ps comming&lt;/div&gt;&lt;div&gt;context switch : frequently&lt;/div&gt;&lt;div&gt;&lt;b&gt;pro&lt;/b&gt;:&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;cons&lt;/b&gt;:&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="330" x="1180" y="1570" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-81" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;align=left;verticalAlign=top;fillColor=#fff2cc;fontSize=10;strokeColor=#d6b656;" value="&lt;b&gt;FCFS&lt;/b&gt; (First-Come, First-Served)&lt;div&gt;&lt;b&gt;pro&lt;/b&gt;:&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;simple, fair with the other of time&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;cons&lt;/b&gt;:&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Convoy Effect,&amp;nbsp; high waiting time, not suitable with interacting system&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="280" x="1450" y="1026" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-82" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;align=left;verticalAlign=top;fontSize=10;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;SJF&lt;/b&gt; (Shortest Job First) / &lt;b&gt;SRTF&lt;/b&gt; (Shortest Remaining Time First).&lt;div&gt;high priority process with processing time or shortest&amp;nbsp;&lt;/div&gt;&lt;div&gt;pro :&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;optimize with small process,&amp;nbsp;&lt;br&gt;&lt;/div&gt;&lt;div&gt;cons:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Hard to Predict,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Starvation with long process&lt;/span&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="390" x="1040" y="1040" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-83" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;align=left;verticalAlign=top;fontSize=10;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Priority Scheduling&lt;/b&gt;&lt;div&gt;each process&amp;nbsp;is assigned a priority value.&amp;nbsp;The CPU is allocated to the process with the highest priority&lt;/div&gt;&lt;div&gt;&lt;b&gt;pro&lt;/b&gt;:&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Immediate Response with high priority task,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Flexibility&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;cons&lt;/b&gt;:&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Starvation with low priority,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Complex Management for determining priority of process.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Solution: Aging -&amp;gt; increasing priority point with long waiting process&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="280" x="1450" y="1130" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-84" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;fontSize=10;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Round Robin (RR)&lt;/b&gt;&lt;div&gt;Each process is allocated a small, fixed unit of CPU time called a &lt;u&gt;Time Quantum&lt;/u&gt;&lt;/div&gt;&lt;div&gt;-&amp;gt;&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;time expires, the process is preempted and moved to the back of the ready queue&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;pro&lt;/b&gt; :&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Fairness,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Ideal for Interactive Systems,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;No Starvation&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;cons&lt;/b&gt; :&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Performance is Time-Quantum Sensitive&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;large : becoming FIFO&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;small : increasing contact switch&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="390" x="1030" y="1150" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-85" edge="1" parent="1" source="ewHc8kYxuxDWHBCdIvr7-88" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fontFamily=Comic Sans MS;fontSize=10;" target="ewHc8kYxuxDWHBCdIvr7-90">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-86" edge="1" parent="1" source="ewHc8kYxuxDWHBCdIvr7-88" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fontFamily=Comic Sans MS;fontSize=10;" target="ewHc8kYxuxDWHBCdIvr7-92">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-87" edge="1" parent="1" source="ewHc8kYxuxDWHBCdIvr7-88" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fontFamily=Comic Sans MS;fontSize=10;" target="ewHc8kYxuxDWHBCdIvr7-192">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-88" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;fontSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Process Synchronization&lt;div&gt;-&amp;gt; archive by&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Mutual Exclusion&lt;/span&gt;&lt;/div&gt;" vertex="1">
