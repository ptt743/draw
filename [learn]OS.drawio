        <mxCell id="ewHc8kYxuxDWHBCdIvr7-264" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontFamily=Comic Sans MS;" value="I/O Management" vertex="1">
          <mxGeometry height="35" width="120" x="3840" y="1392.5" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-265" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=10;fontFamily=Comic Sans MS;strokeColor=default;dashed=1;" value="&lt;b&gt;Programmed I/O (Polling)&lt;/b&gt;:&amp;nbsp;CPU continuously checks the status of the I/O device&lt;div&gt;&lt;b&gt;cons&lt;/b&gt; :&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;extremely wasteful of CPU cycles&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;processor cannot perform any other tasks while waiting for the relatively slow I/O device&lt;/span&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="530" x="4010" y="1290" as="geometry" />
        </mxCell>
