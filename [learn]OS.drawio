          <mxGeometry height="80" width="530" x="4010" y="1370" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-267" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=10;fontFamily=Comic Sans MS;strokeColor=default;dashed=1;" value="&lt;b&gt;Direct Memory Access (DMA)&lt;/b&gt;&lt;div&gt;DMA allows I/O devices to transfer data directly to or from the main memory (RAM) with minimal CPU involvement&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
