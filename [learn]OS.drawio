        <mxCell id="ewHc8kYxuxDWHBCdIvr7-146" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Comic Sans MS;fontSize=10;" value="&lt;b&gt;Paged Memory Management&lt;br&gt;&lt;/b&gt;-&amp;nbsp;process is always divided into &lt;b&gt;multiple fixed-size pages&lt;/b&gt;&lt;div&gt;-&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;Physical memory (RAM) -&amp;gt; frames of the same size.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;-&amp;nbsp;&lt;/span&gt;virtual page maps to a physical frame&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;-&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;process has its own page table&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;pro&lt;/b&gt; :&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;avoid external fragmentation, flexible allocation, supports virtual &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;memory&lt;/span&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;cons&lt;/b&gt; :&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;large page tables, internal fragmentation, slower due to page faults&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="310" x="2010" y="1120" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-147" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Comic Sans MS;fontSize=10;" value="&lt;b&gt;Partitioned Allocation&lt;br&gt;&lt;/b&gt;-&amp;nbsp;main memory is divided into multiple partitions&lt;div&gt;-&amp;nbsp;Each partition hold one process/job&lt;br&gt;-&amp;nbsp;process is placed into a free partition when it starts&lt;br&gt;&lt;b&gt;Cons&lt;/b&gt; :&amp;nbsp;&lt;br&gt;-&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;partition may be &lt;/span&gt;&lt;strong data-start=&quot;408&quot; data-end=&quot;419&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;too big&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;, wasting space&lt;br&gt;-&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Free partitions may be &lt;/span&gt;&lt;strong data-start=&quot;488&quot; data-end=&quot;501&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;scattered -&amp;gt; external fragmentation&lt;/strong&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="310" x="2010" y="970" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-148" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Comic Sans MS;fontSize=10;" value="&lt;b&gt;Single Contiguous Allocation&lt;br&gt;&lt;/b&gt;-&amp;nbsp;small part of memory is reserved for the OS&lt;div&gt;-&amp;nbsp;rest of the memory is given to one single program&lt;/div&gt;&lt;div&gt;-&amp;nbsp;Only one program can run at a time&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="310" x="2010" y="850" as="geometry" />
        </mxCell>
