        <mxCell id="ewHc8kYxuxDWHBCdIvr7-145" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Comic Sans MS;fontSize=10;" value="P1 come back after I/O" vertex="1">
