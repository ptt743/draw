        <mxCell id="ewHc8kYxuxDWHBCdIvr7-184" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;fontSize=10;" value="Major page fault" vertex="1">
          <mxGeometry height="20" width="200" x="3060" y="1500" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-185" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;dashed=1;fontFamily=Comic Sans MS;fontSize=10;" value="Happen when OS access to a virtual page&amp;nbsp; and&amp;nbsp;TLB + page table return th result tell that page is bot existed in RAM" vertex="1">
          <mxGeometry height="60" width="280" x="3090" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-186" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;dashed=1;fontFamily=Comic Sans MS;fontSize=10;" value="- page is &lt;strong data-start=&quot;439&quot; data-end=&quot;457&quot;&gt;not in the TLB&lt;/strong&gt;&lt;div&gt;&lt;strong data-start=&quot;439&quot; data-end=&quot;457&quot;&gt;-&amp;nbsp;&lt;/strong&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;page is already in physical memory, OR&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;The page is in the page cache&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;can be mapped immediately&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: rgb(255, 255, 102);&quot;&gt;No I/O wait → no disk → very fast recovery&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="280" x="3130" y="1380" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-187" parent="1" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;align=left;verticalAlign=top;fontFamily=Comic Sans MS;fontSize=10;" value="&lt;font&gt;-&amp;nbsp;The page is absent from RAM&lt;/font&gt;&lt;div&gt;&lt;font&gt;- OS must read the page from disk to bring it into a free frame&lt;br&gt;&lt;/font&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 102), rgb(37, 37, 0)); color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Millions of times slower than a cache/RAM access.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="50" width="280" x="3130" y="1530" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-188" parent="1" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fontFamily=Comic Sans MS;fontSize=10;" value="Swapping occurs when the OS needs to free RAM due to memory pressure." vertex="1">
          <mxGeometry height="40" width="280" x="2810" y="490" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-189" parent="1" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fontFamily=Comic Sans MS;fontSize=10;" value="Modern systems use paging-based swapping" vertex="1">
          <mxGeometry height="40" width="260" x="3150" y="490" as="geometry" />
        </mxCell>
        <mxCell id="ewHc8kYxuxDWHBCdIvr7-190" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;dashed=1;fontFamily=Comic Sans MS;fontSize=10;" value="-&amp;nbsp;mutual exclusion lock&lt;div&gt;-&amp;nbsp;&lt;strong data-start=&quot;261&quot; data-end=&quot;275&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;one thread&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; can hold the lock&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Has an owner → only the thread that locked it can unlock it&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Used only for protecting a critical section.&lt;/span&gt;&lt;/div&gt;" vertex="1">
