        <mxCell id="VfGdGU-KTwtBBHbvLTI5-24" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="* &lt;b&gt;&lt;u&gt;latency&lt;/u&gt;&lt;/b&gt;&amp;nbsp;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- affects : user experience&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- desired : &lt;b&gt;as low as possible&lt;/b&gt;&lt;br&gt;&lt;div&gt;* &lt;b&gt;&lt;u&gt;throughput&lt;/u&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- affects : number of users can be handle&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- desired : &lt;b&gt;greater&lt;/b&gt; than &lt;b&gt;request rate&lt;/b&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;* &lt;b&gt;&lt;u&gt;errors&lt;/u&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- affects : functional correct&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- desired : &lt;b&gt;None&lt;/b&gt;&amp;nbsp;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="270" x="600" y="160" as="geometry" />
        </mxCell>
        <mxCell id="VfGdGU-KTwtBBHbvLTI5-25" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b&gt;&lt;u&gt;* resource saturation&lt;/u&gt;&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- affects : hardware capacity required&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- desired : &lt;b&gt;efficient utilization&lt;/b&gt; of all system resources&lt;br&gt;&lt;div&gt;* &lt;b&gt;&lt;u&gt;tail latency&lt;/u&gt;&lt;/b&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;gt; indicate queuing of requests&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;gt; getting worse with higher workload&amp;nbsp;&lt;/div&gt;&lt;div&gt;* &lt;b&gt;&lt;u&gt;average latency&lt;/u&gt;&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;gt; hides the effects of tail latency&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;gt; also measure 99(99.9) percentile latency&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="380" x="870" y="160" as="geometry" />
        </mxCell>
        <mxCell id="ijXHwMtGZqLaCloKNkNv-1" edge="1" parent="1" style="endArrow=classic;html=1;rounded=0;fontFamily=Comic Sans MS;fillColor=#0050ef;strokeColor=#001DBC;" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="510" y="1000" as="sourcePoint" />
            <mxPoint x="790" y="1000" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ijXHwMtGZqLaCloKNkNv-2" connectable="0" parent="ijXHwMtGZqLaCloKNkNv-1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" value="&lt;font face=&quot;Comic Sans MS&quot;&gt;Concurrency related latency&lt;/font&gt;" vertex="1">
          <mxGeometry relative="1" x="0.5652" as="geometry">
            <mxPoint x="-79" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ijXHwMtGZqLaCloKNkNv-3" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b&gt;Amdhal&#39;s law&lt;/b&gt;&lt;div&gt;C(N) = N /(1 + alpha*(N-1))&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;C&lt;/b&gt;: capacity , &lt;b&gt;N:&lt;/b&gt; scaling dimension, &lt;b&gt;alpha&lt;/b&gt;: percent parts run serial, resource contention happening&lt;/div&gt;&lt;div&gt;Parallel portion : percentage of process run parallel, the other run serial&lt;/div&gt;&lt;div&gt;Consequence : with (N -&amp;gt; oo) -&amp;gt; lim C(N) = 1/oo&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="440" x="800" y="920" as="geometry" />
        </mxCell>
        <mxCell id="ijXHwMtGZqLaCloKNkNv-4" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" value="&lt;font face=&quot;Comic Sans MS&quot;&gt;&lt;b&gt;Universal Scalability Law&lt;/b&gt;&lt;/font&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;C(N) = N/ (1 + alpha*(N-1) + beta*N*(N-1))&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;with beta is coherency delay =&amp;gt; time to contention a shared resource&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="440" x="800" y="1020" as="geometry" />
        </mxCell>
        <mxCell id="ijXHwMtGZqLaCloKNkNv-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;labelBorderColor=none;fontFamily=Comic Sans MS;fillColor=#d5e8d4;strokeColor=#82b366;" value="Browser" vertex="1">
          <mxGeometry height="40" width="90" x="720.5" y="1180" as="geometry" />
