        <mxCell id="8Y3Pc1Z9YDT49znb_Rtu-1" value="&amp;nbsp;Flags: &lt;b&gt;SYN + ACK&lt;/b&gt;&amp;nbsp;&lt;br&gt;Seq = 5000&lt;br&gt;Ack = 1001&lt;br&gt;&lt;div&gt;Opt(MSS=1460, WS=7, SACKOK, TS)&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=7;fontFamily=Comic Sans MS;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
