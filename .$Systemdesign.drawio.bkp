            <mxPoint x="1520" y="680" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="xFSQszVZrvHgohZOU4dA-17" value="No matter how we spent money to optimize hardware, failures alway have a posibilities to happen because of:&lt;div&gt;- &lt;u&gt;operations&lt;/u&gt;&lt;/div&gt;&lt;div&gt;- &lt;u&gt;development processes&lt;/u&gt;&lt;/div&gt;&lt;div&gt;- &lt;u&gt;Disaster&lt;/u&gt;&lt;/div&gt;&lt;div&gt;- &lt;u&gt;Network or machine failures&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;-&amp;gt; it more economical to recover form a failure instead of preventing it altogether&lt;/b&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1530" y="696" width="431" height="110" as="geometry" />
        </mxCell>
        <mxCell id="YSBGgVX1vi0a6HuOUv6A-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontFamily=Comic Sans MS;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="xFSQszVZrvHgohZOU4dA-18" target="YSBGgVX1vi0a6HuOUv6A-3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1210" y="410" />
              <mxPoint x="1210" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="YSBGgVX1vi0a6HuOUv6A-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontFamily=Comic Sans MS;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="xFSQszVZrvHgohZOU4dA-18" target="YSBGgVX1vi0a6HuOUv6A-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="YSBGgVX1vi0a6HuOUv6A-9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontFamily=Comic Sans MS;fillColor=#0050ef;strokeColor=#001DBC;" edge="1" parent="1" source="xFSQszVZrvHgohZOU4dA-18" target="YSBGgVX1vi0a6HuOUv6A-1">
