        <mxCell id="u2N_AE_eHbUmL58wacCz-16" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontFamily=Comic Sans MS;" value="Cache Challenges" vertex="1">
          <mxGeometry height="20" width="150" x="805.25" y="1910" as="geometry" />
