        <mxCell id="VfGdGU-KTwtBBHbvLTI5-17" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;div&gt;&lt;u&gt;&lt;b&gt;Capacity&lt;/b&gt;&lt;/u&gt;&lt;u&gt;&lt;b&gt;&lt;/b&gt;&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/u&gt;&lt;/div&gt;&lt;u&gt;&lt;b&gt;Efficiency&lt;/b&gt;&lt;/u&gt;&amp;nbsp;&lt;i&gt;mentioned in case handle serial/one process&lt;/i&gt;&lt;div&gt;&lt;span style=&quot;text-decoration-line: underline; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* efficient resource ( hardware)&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* efficient logic (algorithm + DB queries)&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* efficient data storage&amp;nbsp;&lt;span style=&quot;background-color: initial;&quot;&gt;(Data structures + Schema)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- ex: for search features -&amp;gt; use index&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;nbsp; map instead of list if search&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* Cache&lt;br&gt;&lt;div&gt;&lt;u&gt;&lt;b&gt;Concurrency&lt;/b&gt;&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-decoration-line: underline; font-weight: bold; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* hardware :&amp;nbsp;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;nbsp; &amp;nbsp; * software :&amp;nbsp;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ queuing&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ coherence&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="326.25" x="333.75" y="810" as="geometry" />
        </mxCell>
        <mxCell id="VfGdGU-KTwtBBHbvLTI5-18" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;u&gt;&lt;b&gt;Minimize request-response latency&lt;/b&gt;&lt;/u&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;* measured by time units&lt;/div&gt;&lt;div&gt;* wait/idle time ( client) + processing&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;time(server)&lt;/div&gt;&lt;div&gt;=&amp;gt; processing time is the target to be minimize&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="240" x="600" y="300" as="geometry" />
        </mxCell>
        <mxCell id="VfGdGU-KTwtBBHbvLTI5-19" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;u&gt;&lt;b&gt;Maximize throughput&amp;nbsp;&lt;/b&gt;&lt;/u&gt;&lt;div&gt;&lt;u&gt;&lt;br&gt;&lt;/u&gt;&lt;/div&gt;&lt;div&gt;* is rate of requests process per second&amp;nbsp;&lt;/div&gt;&lt;div&gt;* depends on ( latency + capacity)&lt;/div&gt;&lt;div&gt;=&amp;gt; &lt;u&gt;&lt;b&gt;minimize latency&lt;/b&gt;&lt;/u&gt; : minimize throughput&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="250" x="840" y="300" as="geometry" />
        </mxCell>
        <mxCell id="VfGdGU-KTwtBBHbvLTI5-22" edge="1" parent="1" style="endArrow=classic;html=1;rounded=0;fillColor=#0050ef;strokeColor=#001DBC;" value="">
