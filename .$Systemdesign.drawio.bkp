        <mxCell id="ase9dcOjmMQTx-X1SHU3-10" value="&lt;b style=&quot;text-decoration-line: underline;&quot;&gt;Data base&lt;/b&gt;&lt;b style=&quot;&quot;&gt;&amp;nbsp;+&amp;nbsp;&lt;/b&gt;&lt;b style=&quot;text-decoration-line: underline;&quot;&gt;messagequeue&lt;/b&gt;&lt;br&gt;data can be sync in 2 ways :&lt;div&gt;- &lt;b&gt;synchronous&lt;/b&gt;:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* &lt;u&gt;high latency&lt;/u&gt; with write operation bcs of&amp;nbsp; &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;transaction in between nodes is &lt;u&gt;atomic&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* time switch over ~ 0&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* high recover&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;u&gt;-&amp;gt; suitable with active redundancy&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;br&gt;&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="550" y="-621" width="290" height="140" as="geometry" />
        </mxCell>
        <mxCell id="ase9dcOjmMQTx-X1SHU3-15" value="- &lt;b&gt;asynchronous&lt;/b&gt;:&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* transaction is fast&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* when primary db down -&amp;gt; secondary db need to &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;read Write ahead log(WAL) to catch up to &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;primary DB , with some transaction have not done &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;yet -&amp;gt; take time&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* if server of primary db off -&amp;gt; suffer data loss&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;-&amp;gt; suitable with passive redundancy&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="829" y="-592" width="310" height="90" as="geometry" />
        </mxCell>
        <mxCell id="HIalZ3uUfE1h6-yRsq41-1" value="" style="endArrow=none;html=1;rounded=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fillColor=#0050ef;strokeColor=#001DBC;startFill=0;fontFamily=Comic Sans MS;" edge="1" parent="1" target="ase9dcOjmMQTx-X1SHU3-15">
