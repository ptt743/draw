        <mxCell id="EDVhDrsC-hXMby8EWmB1-1" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b&gt;Pessimistic lock&amp;nbsp;&lt;/b&gt;&lt;i style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-&amp;gt; conflicts will likely happen so i lock data before do anything&lt;/i&gt;&lt;div&gt;&lt;b&gt;Pro&lt;/b&gt; : safe&lt;/div&gt;&lt;div&gt;&lt;b&gt;Cons&lt;/b&gt;: hurt performance&lt;/div&gt;&lt;div&gt;Used when : high contention, many threads write/updating&lt;/div&gt;&lt;div&gt;&lt;i&gt;&lt;b&gt;Exp&lt;/b&gt; :&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;synchronized,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;ReentrantLock,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;ReentrantReadWriteLock&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="610" x="1330" y="425" as="geometry" />
        </mxCell>
        <mxCell id="EDVhDrsC-hXMby8EWmB1-2" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b&gt;Optimistic lock&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-&amp;gt; Conflicts are rare -&amp;gt; proceed and check later&amp;nbsp;&lt;/span&gt;&lt;div&gt;&lt;b&gt;Pro&lt;/b&gt;: High performance&lt;/div&gt;&lt;div&gt;&lt;b&gt;Cons&lt;/b&gt;: retry if conflicts happen&lt;/div&gt;&lt;div&gt;Use when : mostly read-heavy workloads&lt;/div&gt;&lt;div&gt;&lt;b&gt;Exp&lt;/b&gt; :&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;StampedLock, CAS&lt;/span&gt;&lt;/div&gt;" vertex="1">
