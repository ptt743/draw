        <mxCell id="5cqEf9HW4aEPetp7FxCr-26" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;u&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;OAuth2 - password flow&lt;/font&gt;&lt;/u&gt;" vertex="1">
          <mxGeometry height="30" width="157.5" x="370" y="-400" as="geometry" />
        </mxCell>
        <mxCell id="5cqEf9HW4aEPetp7FxCr-29" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;u&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;OAuth2 Token Types&lt;/font&gt;&lt;/u&gt;&lt;div&gt;- &lt;b&gt;Bearer token&lt;/b&gt;:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* any one have token can use it&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* just integrity protection&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* requires TLS for confidentially&amp;nbsp;&lt;br&gt;&lt;/div&gt;&lt;div&gt;- &lt;b&gt;MAC&lt;/b&gt;(holder of key token)&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* both client and server need possess symmetric key&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* can work without TLS but using TLS to get token from server&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* integrity&amp;nbsp; +&amp;nbsp; data origin protection&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="420" x="440" y="-360" as="geometry" />
        </mxCell>
        <mxCell id="e9IoIL1gtBtxBWrJJUSa-1" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;u&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;Token formats&lt;/font&gt;&lt;/u&gt;&lt;div&gt;- compact and URL safe&lt;br&gt;&lt;div&gt;- JSON (&lt;i&gt;json&lt;/i&gt;)&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* header and payload encode by HS256| RS256&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* {&lt;b&gt;Header&lt;/b&gt;}{&lt;b&gt;Payload&lt;/b&gt;}{&lt;b&gt;Signature&lt;/b&gt;}&lt;br&gt;&lt;/div&gt;&lt;div&gt;- XAML (&lt;i&gt;XML&lt;/i&gt;)&lt;/div&gt;&lt;/div&gt;&lt;div&gt;- require parsing&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="341" x="440" y="-220" as="geometry" />
        </mxCell>
        <mxCell id="e9IoIL1gtBtxBWrJJUSa-5" edge="1" parent="1" source="e9IoIL1gtBtxBWrJJUSa-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fillColor=#0050ef;strokeColor=#001DBC;fontFamily=Comic Sans MS;" target="5cqEf9HW4aEPetp7FxCr-29">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9IoIL1gtBtxBWrJJUSa-7" edge="1" parent="1" source="e9IoIL1gtBtxBWrJJUSa-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fillColor=#0050ef;strokeColor=#001DBC;fontFamily=Comic Sans MS;" target="e9IoIL1gtBtxBWrJJUSa-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9IoIL1gtBtxBWrJJUSa-9" edge="1" parent="1" source="e9IoIL1gtBtxBWrJJUSa-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fillColor=#0050ef;strokeColor=#001DBC;fontFamily=Comic Sans MS;" target="e9IoIL1gtBtxBWrJJUSa-8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9IoIL1gtBtxBWrJJUSa-3" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#CC0000;fontFamily=Comic Sans MS;" value="&lt;u&gt;Token&lt;/u&gt;" vertex="1">
          <mxGeometry height="30" width="60" x="340" y="-250" as="geometry" />
        </mxCell>
        <mxCell id="e9IoIL1gtBtxBWrJJUSa-8" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;u&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;Token Storage&lt;/font&gt;&lt;/u&gt;&lt;div&gt;- &lt;b&gt;Web client&lt;/b&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*&lt;u&gt; Browser cookies&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ can be make &lt;b&gt;httponly&lt;/b&gt;(just http access)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ vulnerable to CSRF attack&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* &lt;u&gt;Browser local storage&lt;/u&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ accessible by javascript( main reason not use)&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;# vulnerable by XSS&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ should not be used&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;- &lt;b&gt;Single page application&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* non safe place to store token for SPA&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+&amp;nbsp;local storage is unsafe&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* store token temporarily in memory&lt;br&gt;&lt;/div&gt;&lt;div&gt;- &lt;b&gt;Mobile&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* mobile app use keychain(IOS), keystore(Adnroid)&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="350" x="440" y="-100" as="geometry" />
        </mxCell>
        <mxCell id="f4ioiUhAqGSsGf76CIWZ-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=4;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Comic Sans MS;" value="&lt;font size=&quot;1&quot;&gt;using public key of AS to verify token&lt;/font&gt;" vertex="1">
          <mxGeometry height="40" width="85.5" x="-98.75" y="-446" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
