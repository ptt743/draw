        <mxCell id="xFSQszVZrvHgohZOU4dA-15" value="&lt;b&gt;Failure can be partial and independent&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;fontStyle=4" vertex="1" parent="1">
