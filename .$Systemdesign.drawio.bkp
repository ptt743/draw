        <mxCell id="u2N_AE_eHbUmL58wacCz-18" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b&gt;Cach inValidate &amp;amp; Cache Inconsistency&lt;/b&gt;&lt;div&gt;&lt;b&gt;-&amp;gt; require update/delete of cached value upon update&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ No cache inconsistency if same server&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ if DB &amp;amp; Cache in diff server, we can : =&amp;gt; leading &lt;b&gt;eventual consistency&lt;/b&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* write through/ write around&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* background sync jods&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*&amp;nbsp; event-driven updates&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;-&amp;gt; TTL value can be used to aged data&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ low : cache hit down , inconsistency interval down&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ high : cache hit up , inconsistency interval up&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="460" x="1080" y="1900" as="geometry" />
        </mxCell>
