        <mxCell id="HIalZ3uUfE1h6-yRsq41-4" value="&lt;b&gt;&lt;u&gt;Cache&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;div&gt;- data&amp;nbsp; in cache do not need to be redundancy because of if cache not hit, request go DB( primary source of data)&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" vertex="1" parent="1">
          <mxGeometry x="719" y="-751" width="370" height="60" as="geometry" />
