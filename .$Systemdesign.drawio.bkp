        <mxCell id="u2N_AE_eHbUmL58wacCz-11" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b&gt;Exclusive Cache&lt;/b&gt;&lt;div&gt;+ &lt;b&gt;low latency&lt;/b&gt;&lt;/div&gt;&lt;div&gt;+ without &lt;b&gt;routing&lt;/b&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;gt; duplication data&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;gt; uneven load&amp;nbsp;&lt;br&gt;&lt;/div&gt;&lt;div&gt;+ using for :&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;gt; &lt;b&gt;small datasets&lt;/b&gt; -&amp;gt; dup datas in specific rate&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;gt; session cache&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="310" x="1480" y="1640" as="geometry" />
        </mxCell>
        <mxCell id="u2N_AE_eHbUmL58wacCz-13" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b&gt;Shared Cache&lt;/b&gt;&lt;div&gt;+ higher latency&lt;/div&gt;&lt;div&gt;+ &lt;b&gt;can scale&lt;/b&gt; to distributed cache&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;gt; memcache&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;gt;redis&lt;br&gt;&lt;/div&gt;&lt;div&gt;+ using for larger datasets&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="190" x="1600" y="1480" as="geometry" />
        </mxCell>
        <mxCell id="u2N_AE_eHbUmL58wacCz-15" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b&gt;Limited cache space in early evictions&lt;/b&gt;&lt;div&gt;-&amp;gt; prefer caching frequently accessed objects&lt;/div&gt;&lt;div&gt;-&amp;gt; average size of object should be as small as possible&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
