        <mxCell id="OaPi2JGeNaKhquKWLYuI-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Comic Sans MS;" value="Order processing" vertex="1">
