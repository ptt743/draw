        <mxCell id="VfGdGU-KTwtBBHbvLTI5-12" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;font color=&quot;#cc0000&quot;&gt;&lt;u&gt;Causing by any problems of queuing in somewhere&lt;/u&gt;&lt;/font&gt;&lt;div&gt;* Network socket queue&lt;/div&gt;&lt;div&gt;* DB IO Queue &lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;i&gt;=&amp;gt; resolve by decreasing number of request to DB( batching)&lt;/i&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;* OS run queue&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#cc0000&quot;&gt;&lt;u&gt;Reason queue build-up&lt;/u&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;* inefficient slow processing &lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;i&gt;=&amp;gt; optimize code&lt;/i&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;* Serial resource access &lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;i&gt;=&amp;gt; threads wait for a thread&lt;/i&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;* limit Resource capacity&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="137" width="310" x="640" y="633.5" as="geometry" />
        </mxCell>
        <mxCell id="VfGdGU-KTwtBBHbvLTI5-14" edge="1" parent="1" source="VfGdGU-KTwtBBHbvLTI5-10" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;fillColor=#0050ef;strokeColor=#001DBC;fontFamily=Comic Sans MS;" target="VfGdGU-KTwtBBHbvLTI5-17" value="">
