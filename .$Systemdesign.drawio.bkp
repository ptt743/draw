        <mxCell id="VfGdGU-KTwtBBHbvLTI5-15" connectable="0" parent="VfGdGU-KTwtBBHbvLTI5-14" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontFamily=Comic Sans MS;" value="&lt;i&gt;Solved by&lt;/i&gt;" vertex="1">
