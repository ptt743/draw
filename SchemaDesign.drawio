t;br&gt;&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;background-color: transparent; color: rgb(110, 118, 135);&quot;&gt;-- Trả về cursor = post_id nhỏ nhất trong batch (vd: 1234567890)&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;background-color: transparent; color: rgb(110, 118, 135);&quot;&gt;--&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;token token&quot; style=&quot;background-color: transparent; color: rgb(110, 118, 135);&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;token token&quot; style=&quot;background-color: transparent; color: rgb(110, 118, 135);&quot;&gt;Page 2: using cursor from page 1&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;token token&quot; style=&quot;background-color: transparent; color: rgb(129, 0, 194);&quot;&gt;SELECT&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; post_id&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;background-color: transparent; color: rgb(43, 48, 59);&quot;&gt;,&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; content&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;background-color: transparent; color: rgb(43, 48, 59);&quot;&gt;,&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; created_at &lt;br&gt;&lt;/span&gt;&lt;span class=&quot;token token&quot; style=&quot;background-color: transparent; color: rgb(129, 0, 194);&quot;&gt;FROM&lt;/span&gt;&lt;span style=&quot;background-color: transparen