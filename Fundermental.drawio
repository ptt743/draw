        <mxCell id="nis7yasxWMMKgdfyHNSh-78" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;fontSize=11;" value="&lt;u&gt;&lt;b&gt;SSTable(sorted string table) (segment)&lt;/b&gt;&lt;/u&gt;&lt;div&gt;- key-value required sort in key.&lt;br&gt;- each key appear just one time( &lt;u&gt;compaction &amp;amp; merging ensure that&lt;/u&gt;)&lt;/div&gt;&lt;div&gt;+&amp;nbsp;benefits :&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*&amp;nbsp;range query becomes more possible&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* merging become more simple and effective&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="105" width="344" x="1386" y="1007" as="geometry" />
        </mxCell>
        <mxCell id="nis7yasxWMMKgdfyHNSh-82" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;strokeColor=#d6b656;fillColor=#fff2cc;fontSize=11;" value="&lt;div&gt;+ maintaining a sorted structure in memory easy than disk&lt;/div&gt;&lt;div&gt;+ size of memtable grow larger gradually -&amp;gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;write&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* change to immutable and write to disk as a SSTable file&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*&amp;nbsp;create new empty one for new incoming write&lt;/div&gt;&lt;div&gt;read&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* first searching in memtable&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;* second find in most recent SStable file ( each SStable file also have a memory index)&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="147" width="501" x="2081" y="900.31" as="geometry" />
        </mxCell>
