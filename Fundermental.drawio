        <mxCell id="ZtOpQCXVzoBaf1M-dsWP-7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Comic Sans MS;fontSize=10;" value="&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: inherit; color: rgb(170, 13, 145); letter-spacing: -0.308px; white-space: pre;&quot;&gt;CREATE&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt; INDEX idx_sessions_token_hash &lt;/span&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: inherit; color: rgb(170, 13, 145); letter-spacing: -0.308px; white-space: pre;&quot;&gt;ON&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt; user_sessions &lt;/span&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: inherit; color: rgb(170, 13, 145); letter-spacing: -0.308px; white-space: pre;&quot;&gt;USING&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt; HASH(session_token);&lt;/span&gt;&lt;br style=&quot;box-sizing: inherit; caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre;&quot;&gt;&lt;br style=&quot;box-sizing: inherit; caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre;&quot;&gt;&lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: inherit; color: rgb(0, 116, 0); letter-spacing: -0.308px; white-space: pre;&quot;&gt;-- B-Tree index for expiration cleanup queries&lt;/span&gt;&lt;br style=&quot;box-sizing: inherit; caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre;&quot;&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: inher