, 0); letter-spacing: -0.308px; white-space: pre;&quot;&gt;-- This query benefits from the hash index (equality check)&lt;/span&gt;&lt;br style=&quot;box-sizing: inherit; caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre;&quot;&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: inherit; color: rgb(170, 13, 145); letter-spacing: -0.308px; white-space: pre;&quot;&gt;SELECT&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt; &lt;/span&gt;&lt;span class=&quot;hljs-operator&quot; style=&quot;box-sizing: inherit; caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre;&quot;&gt;*&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt; &lt;/span&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: inherit; color: rgb(170, 13, 145); letter-spacing: -0.308px; white-space: pre;&quot;&gt;FROM&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt; users &lt;/span&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: inherit; color: rgb(170, 13, 145); letter-spacing: -0.308px; white-space: pre;&quot;&gt;WHERE&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt; username &lt;/span&gt;&lt;span class=&quot;hljs-operator&quot; style=&quot;box-sizing: inherit; caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt; &lt;/span&gt;&lt;span class=&quot;hljs-string&quot; style=&quot;box-sizing: inherit; color: rgb(196, 26, 22); letter-spacing: -0.308px; white-space: pre;&quot;&gt;&#39;johndoe123&#39;&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt;;&lt;/span&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: inherit; color: rgb(0, 116, 0); letter-spacing: -0.308px; white-space: pre;&quot;&gt;-- But this query CANNOT use the hash index (range query)&lt;/span&gt;&lt;br style=&quot;box-sizing: inherit; caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre;&quot;&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: inherit; color: rgb(170, 13, 145); letter-spacing: -0.308px; white-space: pre;&quot;&gt;SELECT&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt; &lt;/span&gt;&lt;span class=&quot;hljs-operator&quot; style=&quot;box-sizing: inherit; caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre;&quot;&gt;*&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt; &lt;/span&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: inherit; color: rgb(170, 13, 145); letter-spacing: -0.308px; white-space: pre;&quot;&gt;FROM&lt;/span&gt;&lt;span style=&quot;caret-color: rgb(36, 36, 36); color: rgb(36, 36, 36); letter-spacing: -0.308px; white-space: pre; background-color: rgb(249, 249, 249);&quot;&gt; users &lt;/span&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;b